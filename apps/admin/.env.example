# Supabase Proje URL'i (Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonim (Public) API Anahtari
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Admin panelinin public URL'i (production'da domain adresiniz)
NEXT_PUBLIC_SITE_URL=https://admin.newsa.com.tr

# Sentry Hata Izleme
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
