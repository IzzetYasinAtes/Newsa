# Supabase Proje URL'i (Supabase Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonim (Public) API Anahtari
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# CORS icin izin verilen origin'ler (virgülle ayrilmis liste)
CORS_ALLOWED_ORIGINS=https://newsa.com.tr,https://admin.newsa.com.tr
